# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

#scripts
/scripts

# next.js
/.next/
/out/
.turbo/

# production
/build

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# misc
*.pem

# debug & logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# tooling caches
.eslintcache
.prettiercache
.stylelintcache

# IDE / editors
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
*~
.history/

# husky (regenerated by `npx husky`)
.husky/

# Claude Code (config locale)
.claude/

# supabase CLI (local state, not committed)
/supabase/.branches
/supabase/.temp
/supabase/seed.sql

# misc backups
*.bak
*.tmp
*.temp
